generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

model Profile {
  id                 String     @id @db.Uuid

  fullName           String?    @map("full_name")
  dateOfBirth        DateTime?  @map("date_of_birth") @db.Date
  heightCm           Float?     @map("height_cm")
  weightKg           Float?     @map("weight_kg")

  diagnosedAt        DateTime?  @map("diagnosed_at") @db.Date
  phenotype          Phenotype?

  onboardingComplete Boolean    @default(false) @map("onboarding_complete")

  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  cycles             Cycle[]
  symptomLogs        SymptomLog[]
  @@map("profiles")
  @@schema("public")
}

model Cycle {
  id            String         @id @default(uuid()) @db.Uuid
  profileId     String         @map("profile_id") @db.Uuid
  profile       Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)

  startDate     DateTime       @map("start_date") @db.Date
  endDate       DateTime?      @map("end_date") @db.Date
  flowIntensity FlowIntensity? @map("flow_intensity")

  notes         String?

  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([profileId, startDate])
  @@map("cycles")
  @@schema("public")
}

model SymptomLog {
  id        String    @id @default(uuid()) @db.Uuid
  profileId String    @map("profile_id") @db.Uuid
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  date      DateTime  @db.Date
  symptoms  Json      // { acne: 3, mood_low: 4, fatigue: 5, cravings: 2, bloating: 3, headache: 0 }
  mood      Int?      // overall mood 1-5
  energy    Int?      // overall energy 1-5
  notes     String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@unique([profileId, date])
  @@index([profileId, date])
  @@map("symptom_logs")
  @@schema("public")
}

enum Phenotype {
  INSULIN_RESISTANT
  INFLAMMATORY
  ADRENAL
  LEAN
  UNKNOWN

  @@schema("public")
}

enum FlowIntensity {
  SPOTTING
  LIGHT
  MEDIUM
  HEAVY

  @@schema("public")
}