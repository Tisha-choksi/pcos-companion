generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

model Profile {
  id                 String     @id @db.Uuid

  fullName           String?    @map("full_name")
  dateOfBirth        DateTime?  @map("date_of_birth") @db.Date
  heightCm           Float?     @map("height_cm")
  weightKg           Float?     @map("weight_kg")

  diagnosedAt        DateTime?  @map("diagnosed_at") @db.Date
  diagnosisStatus    DiagnosisStatus? @map("diagnosis_status")
  phenotype          Phenotype?
  phenotypeAnswers   Json?      @map("phenotype_answers")

  onboardingComplete Boolean    @default(false) @map("onboarding_complete")
  onboardingStep     Int        @default(0) @map("onboarding_step")

  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  cycles             Cycle[]
  symptomLogs        SymptomLog[]
  medications        Medication[]
  dietLogs           DietLog[]
  workoutLogs        WorkoutLog[]

  @@map("profiles")
  @@schema("public")
}

model Cycle {
  id            String         @id @default(uuid()) @db.Uuid
  profileId     String         @map("profile_id") @db.Uuid
  profile       Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)

  startDate     DateTime       @map("start_date") @db.Date
  endDate       DateTime?      @map("end_date") @db.Date
  flowIntensity FlowIntensity? @map("flow_intensity")

  notes         String?

  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([profileId, startDate])
  @@map("cycles")
  @@schema("public")
}

model SymptomLog {
  id        String    @id @default(uuid()) @db.Uuid
  profileId String    @map("profile_id") @db.Uuid
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  date      DateTime  @db.Date
  symptoms  Json
  mood      Int?
  energy    Int?
  notes     String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@unique([profileId, date])
  @@index([profileId, date])
  @@map("symptom_logs")
  @@schema("public")
}

model Medication {
  id           String    @id @default(uuid()) @db.Uuid
  profileId    String    @map("profile_id") @db.Uuid
  profile      Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name         String
  category     MedicationCategory
  dosage       String?
  frequency    String?
  startedAt    DateTime  @map("started_at") @db.Date
  stoppedAt    DateTime? @map("stopped_at") @db.Date
  notes        String?

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([profileId, startedAt])
  @@map("medications")
  @@schema("public")
}

model DietLog {
  id           String      @id @default(uuid()) @db.Uuid
  profileId    String      @map("profile_id") @db.Uuid
  profile      Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)

  date         DateTime    @db.Date
  mealType     MealType    @map("meal_type")
  description  String
  giCategory   GICategory? @map("gi_category")
  notes        String?

  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@index([profileId, date])
  @@map("diet_logs")
  @@schema("public")
}

model WorkoutLog {
  id           String       @id @default(uuid()) @db.Uuid
  profileId    String       @map("profile_id") @db.Uuid
  profile      Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)

  date         DateTime     @db.Date
  workoutType  WorkoutType  @map("workout_type")
  durationMin  Int          @map("duration_min")
  intensity    Intensity?
  notes        String?

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@index([profileId, date])
  @@map("workout_logs")
  @@schema("public")
}

enum Phenotype {
  INSULIN_RESISTANT
  INFLAMMATORY
  ADRENAL
  LEAN
  UNKNOWN

  @@schema("public")
}

enum DiagnosisStatus {
  DIAGNOSED
  SUSPECTED
  NOT_SURE

  @@schema("public")
}

enum FlowIntensity {
  SPOTTING
  LIGHT
  MEDIUM
  HEAVY

  @@schema("public")
}

enum MedicationCategory {
  INSULIN_SENSITIZER
  ANDROGEN_BLOCKER
  HORMONAL
  SUPPLEMENT
  OTHER

  @@schema("public")
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK

  @@schema("public")
}

enum GICategory {
  LOW
  MEDIUM
  HIGH

  @@schema("public")
}

enum WorkoutType {
  STRENGTH
  WALK
  YOGA
  CARDIO
  HIIT
  PILATES
  OTHER

  @@schema("public")
}

enum Intensity {
  LIGHT
  MODERATE
  INTENSE

  @@schema("public")
}

model Conversation {
  id           String     @id @default(uuid()) @db.Uuid
  profileId    String     @map("profile_id") @db.Uuid
  profile      Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)

  title        String?    // optional, can be auto-generated
  archived     Boolean    @default(false)

  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  messages     Message[]

  @@index([profileId, archived, updatedAt])
  @@map("conversations")
  @@schema("public")
}

model Message {
  id              String        @id @default(uuid()) @db.Uuid
  conversationId  String        @map("conversation_id") @db.Uuid
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role            MessageRole
  content         String

  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([conversationId, createdAt])
  @@map("messages")
  @@schema("public")
}

enum MessageRole {
  USER
  ASSISTANT

  @@schema("public")
}